{
  "_comment": "Single source of truth for the CI build matrix. ci.yml diffs changed files against these paths and dispatches _service-ci.yml per changed service. lang drives the test/CodeQL toolchain. context+dockerfile are passed to docker build. NOTE: backend services build with context 'app' (their Dockerfiles COPY backend-services/<svc> + backend-services/shared); payment-service-go and frontend use self-contained contexts. Legacy Node payment-service is intentionally excluded (replaced by payment-service-go).",
  "services": [
    { "name": "api-gateway-service",    "lang": "node",   "path": "app/backend-services/api-gateway-service",    "context": "app", "dockerfile": "app/backend-services/api-gateway-service/Dockerfile",    "port": 3000, "node": "18", "image": "luxecart-api-gateway-service" },
    { "name": "auth-service",           "lang": "node",   "path": "app/backend-services/auth-service",           "context": "app", "dockerfile": "app/backend-services/auth-service/Dockerfile",           "port": 3001, "node": "18", "image": "luxecart-auth-service" },
    { "name": "user-service",           "lang": "node",   "path": "app/backend-services/user-service",           "context": "app", "dockerfile": "app/backend-services/user-service/Dockerfile",           "port": 3002, "node": "18", "image": "luxecart-user-service" },
    { "name": "product-service",        "lang": "java",   "path": "app/backend-services/product-service",        "context": "app", "dockerfile": "app/backend-services/product-service/Dockerfile",        "port": 3003, "java": "21", "image": "luxecart-product-service" },
    { "name": "cart-service",           "lang": "node",   "path": "app/backend-services/cart-service",           "context": "app", "dockerfile": "app/backend-services/cart-service/Dockerfile",           "port": 3004, "node": "18", "image": "luxecart-cart-service" },
    { "name": "order-service",          "lang": "node",   "path": "app/backend-services/order-service",          "context": "app", "dockerfile": "app/backend-services/order-service/Dockerfile",          "port": 3005, "node": "18", "image": "luxecart-order-service" },
    { "name": "review-service",         "lang": "node",   "path": "app/backend-services/review-service",         "context": "app", "dockerfile": "app/backend-services/review-service/Dockerfile",         "port": 3006, "node": "18", "image": "luxecart-review-service" },
    { "name": "rating-service",         "lang": "node",   "path": "app/backend-services/rating-service",         "context": "app", "dockerfile": "app/backend-services/rating-service/Dockerfile",         "port": 3007, "node": "18", "image": "luxecart-rating-service" },
    { "name": "payment-service-go",     "lang": "go",     "path": "app/backend-services/payment-service-go",     "context": "app/backend-services/payment-service-go", "dockerfile": "app/backend-services/payment-service-go/Dockerfile", "port": 3018, "go": "1.24", "image": "luxecart-payment-service-go" },
    { "name": "notification-service",   "lang": "node",   "path": "app/backend-services/notification-service",   "context": "app", "dockerfile": "app/backend-services/notification-service/Dockerfile",   "port": 3009, "node": "18", "image": "luxecart-notification-service" },
    { "name": "admin-service",          "lang": "node",   "path": "app/backend-services/admin-service",          "context": "app", "dockerfile": "app/backend-services/admin-service/Dockerfile",          "port": 3010, "node": "18", "image": "luxecart-admin-service" },
    { "name": "inventory-service",      "lang": "node",   "path": "app/backend-services/inventory-service",      "context": "app", "dockerfile": "app/backend-services/inventory-service/Dockerfile",      "port": 3011, "node": "18", "image": "luxecart-inventory-service" },
    { "name": "search-service",         "lang": "node",   "path": "app/backend-services/search-service",         "context": "app", "dockerfile": "app/backend-services/search-service/Dockerfile",         "port": 3012, "node": "18", "image": "luxecart-search-service" },
    { "name": "analytics-service",      "lang": "python", "path": "app/backend-services/analytics-service",      "context": "app", "dockerfile": "app/backend-services/analytics-service/Dockerfile",      "port": 3013, "python": "3.11", "image": "luxecart-analytics-service" },
    { "name": "recommendation-service", "lang": "python", "path": "app/backend-services/recommendation-service", "context": "app", "dockerfile": "app/backend-services/recommendation-service/Dockerfile", "port": 3014, "python": "3.11", "image": "luxecart-recommendation-service" },
    { "name": "email-service",          "lang": "python", "path": "app/backend-services/email-service",          "context": "app", "dockerfile": "app/backend-services/email-service/Dockerfile",          "port": 3015, "python": "3.11", "image": "luxecart-email-service" },
    { "name": "image-service",          "lang": "node",   "path": "app/backend-services/image-service",          "context": "app", "dockerfile": "app/backend-services/image-service/Dockerfile",          "port": 3016, "node": "20", "image": "luxecart-image-service" },
    { "name": "frontend",               "lang": "nextjs", "path": "app/frontend",                                "context": "app/frontend", "dockerfile": "app/frontend/Dockerfile",                 "port": 3000, "node": "20", "image": "luxecart-frontend" }
  ]
}
