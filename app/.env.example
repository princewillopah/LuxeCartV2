# ─────────────────────────────────────────────────────────────────────────────
# LuxeCart — environment template
# Copy this file to `.env` (gitignored) and fill in real values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Public host the browser uses to reach the api-gateway / frontend.
# On a remote VM this MUST be the VM's public IP or DNS name, NOT localhost.
PUBLIC_API_URL=http://localhost:18080
PUBLIC_FRONTEND_URL=http://localhost:18081

# Comma-separated list of browser origins the api-gateway will accept (CORS).
# Wildcard '*' is intentionally not allowed because we send credentials.
CORS_ORIGINS=http://localhost:18081,http://127.0.0.1:18081

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ecommerce

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me

# ── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_USER=ecommerce
RABBITMQ_PASSWORD=change-me

# ── App / Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# REQUIRED: must be at least 32 chars or auth-service / api-gateway will
# refuse to boot (fail-fast on weak/missing secret).
JWT_SECRET=change-me-with-openssl-rand-hex-32-to-at-least-32-chars

# ── Grafana admin ───────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# ── SMTP (e.g. Gmail App Password) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@example.com
SMTP_PASSWORD=change-me
FROM_EMAIL=LuxeCart <noreply@example.com>

# ── AWS / S3 (image-service) ────────────────────────────────────────────────
# Locally these are real IAM-user keys; in EKS leave them blank and use IRSA.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=change-me
S3_BUCKET_NAME=luxecart-images
